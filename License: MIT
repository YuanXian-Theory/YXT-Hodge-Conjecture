#!/usr/bin/env python3
"""
YuanXian Theory - Hodge Conjecture Verification Pipeline
"""

import json
import sys
from sage.all import *
from sage.hodge_operator import HodgeLaplacian

def main():
    print("=== YuanXian Theory Hodge Conjecture Verification ===\n")
    
    hl = HodgeLaplacian()
    results = hl.run_full_verification(dim=64)
    
    print(f"Verification completed. Max deviation: {results['max_deviation']}")
    
    # Save results
    with open("data/hodge_verification.json", "w") as f:
        json.dump(results, f, indent=2)
    
    print("Results saved to data/hodge_verification.json")

if __name__ == "__main__":
    main()
